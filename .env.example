# Local compose builds; prod compose pulls from GHCR.
IMAGE_TAG=latest

# Public site URL (Cloudflare Tunnel hostname)
NEXTAUTH_URL=https://gnosis.adityatripathi.dev
AUTH_URL=https://gnosis.adityatripathi.dev
AUTH_TRUST_HOST=true

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-generated-secret
AUTH_SECRET=your-generated-secret

# MongoDB (internal Docker network only — not published to the host)
MONGO_INITDB_ROOT_USERNAME=gnosis
MONGO_INITDB_ROOT_PASSWORD=change-me-strong-password
MONGO_DB=gnosis

GROQ_API_KEY=your-groq-api-key

# Optional public API origin (same as site for this app)
NEXT_PUBLIC_API_URL=https://gnosis.adityatripathi.dev
